{
    "name": "smart-restaurant-pos",
    "description": "Smart Restaurant Point of Sale System with QR Code Ordering",
    "version": "1.0.0",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Restaurant Dev Team",
            "email": "dev@smartrestaurant.com"
        }
    ],
    "require": {
        "php": ">=7.4.0",
        "dompdf/dompdf": "^2.0",
        "chillerlan/php-qrcode": "^4.3",
        "phpoffice/phpspreadsheet": "^1.28"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5",
        "mikey179/vfsstream": "^1.6",
        "phpmd/phpmd": "^2.13",
        "squizlabs/php_codesniffer": "^3.7"
    },
    "autoload": {
        "psr-4": {
            "App\\": "application/",
            "Libraries\\": "application/libraries/",
            "Models\\": "application/models/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "scripts": {
        "post-install-cmd": [
            "@php -r \"file_exists('vendor/autoload.php') ? require 'vendor/autoload.php' : null;\""
        ],
        "post-update-cmd": [
            "@php -r \"file_exists('vendor/autoload.php') ? require 'vendor/autoload.php' : null;\""
        ],
        "test": "phpunit",
        "lint": "phpcs --standard=PSR12 application/",
        "fix": "phpcbf --standard=PSR12 application/"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
